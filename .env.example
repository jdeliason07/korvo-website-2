PORT=3000

# Resend (https://resend.com) — free tier works great
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact form emails get sent
MAIL_TO=jack@korvo.ai

# Admin panel password — choose something strong.
# Also gates the Discovery Intake form at /admin/discovery.
ADMIN_PASS=your-strong-admin-password-here

# ── Discovery-call storage ────────────────────────────────────────────────
# Postgres (recommended on Railway): add a Postgres database and Railway
# injects DATABASE_URL automatically. When set, discovery calls are stored
# in a `discovery_calls` table (meta in columns, answers as JSONB).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# SSL is auto-detected: off for Railway's internal URL (the default), on when
# the connection string includes sslmode=require. Override only if needed:
#   PGSSL=require   (force SSL, e.g. an external/proxy URL that needs it)
#   PGSSL=disable   (force off)
# PGSSL=require

# If DATABASE_URL is NOT set, records are stored as JSON on disk instead.
# Point DATA_DIR at a mounted Railway volume so data survives redeploys
# (the local default is ./data, which is fine for development).
# DATA_DIR=/data
